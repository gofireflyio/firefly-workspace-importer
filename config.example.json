{
  "vcs": {
    "integrationId": "your-firefly-vcs-integration-id"
  },
  "repositories": [
    "owner/repo-1",
    "owner/repo-2"
  ],
  "workspace": {
    "runner_type": "firefly",
    "iac_type": "opentofu",
    "terraform_version": "1.11.6",
    "execution_triggers": ["merge"],
    "apply_rule": "manual",
    "is_remote": true,
    "variables": [
      {
        "key": "EXAMPLE_ENV_VAR",
        "value": "example-value",
        "sensitivity": "string",
        "destination": "env"
      }
    ],
    "consumed_variable_sets": []
  },
  "projects": {
    "create": true,
    "nested": false,
    "project_id": null,
    "main_members": [
      {
        "userId": "user-id-1",
        "role": "admin"
      }
    ],
    "main_variables": [
      {
        "key": "ENV",
        "value": "production",
        "sensitivity": "string",
        "destination": "env"
      }
    ],
    "path_members": {
      "/aws/production": [
        {
          "userId": "user-id-1",
          "role": "admin"
        }
      ]
    },
    "path_variables": {
      "/aws/production": [
        {
          "key": "AWS_REGION",
          "value": "us-east-1",
          "sensitivity": "string",
          "destination": "env"
        }
      ]
    }
  }
}
