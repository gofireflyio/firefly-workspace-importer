# Firefly Workspace Automation - Secrets
# Copy this file to .env and fill in real values. Never commit .env.
#
# Environment variables already set in your shell take precedence
# over values in this file.

# ---- Firefly API credentials (required) ----
# Get these from Firefly: Settings -> Access Management -> Create Key Pair.
FIREFLY_ACCESS_KEY=
FIREFLY_SECRET_KEY=

# Optional: override the Firefly API base URL (default: https://api.firefly.ai)
# FIREFLY_API_URL=https://api.firefly.ai

# ---- GitHub token (required for private repos and higher rate limits) ----
# Generate at: https://github.com/settings/tokens/new
# Scopes: none for public repos; "repo" for private repos.
GITHUB_TOKEN=
